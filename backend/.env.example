# 🔧 EyeLeads Eyewear Store Backend Environmental Variables Template
# Copy this file to .env inside your backend folder and adjust credentials.

# MongoDB connection string (Atlas or local instance)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/eyelead

# Authentication parameters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_generated_random_64_byte_hex_string
MOCK_ADMIN_PASSWORD=your_mock_admin_password_here

# Razorpay Payment Gateway API Keys
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# EmailJS credentials for order confirmation receipts
EMAILJS_SERVICE_ID=service_eyeleads_xxxx
EMAILJS_TEMPLATE_ID=template_eyeleads_confirm_xxxx
EMAILJS_USER_ID=user_eyeleads_public_key_xxxx

# Express Server Port & Environments
PORT=5000
NODE_ENV=development
# Backend URL (e.g. http://localhost:5000 in dev, or your production backend domain in prod)
BACKEND_URL=http://localhost:5000

# Allowed cross-origin frontend URL
FRONTEND_URL=http://localhost:5173

# Shiprocket API credentials (Settings → API in Shiprocket dashboard)
SHIPROCKET_EMAIL=your_shiprocket_api_email
SHIPROCKET_PASSWORD=your_shiprocket_api_password

# Shiprocket pickup location nickname (exact name as set in Shiprocket dashboard → Settings → Pickup Addresses)
SHIPROCKET_PICKUP_LOCATION=Primary

# Pincode of your actual Shiprocket pickup location (Surat warehouse) — used for courier rate comparison
SHIPROCKET_PICKUP_PINCODE=395007

# Shared secret Shiprocket will send back so we can verify webhook calls are genuine.
# Set the same value in Shiprocket dashboard → Settings → API → Webhooks → "Custom Header Token/Secret"
SHIPROCKET_WEBHOOK_TOKEN=generate_a_long_random_string_here

# Real inbox that receives new-order alerts AND admin login OTP codes
ADMIN_NOTIFICATION_EMAIL=eyeleadscare@gmail.com
