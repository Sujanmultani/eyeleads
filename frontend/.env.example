# 🔧 EyeLeads Eyewear Store Frontend Environmental Variables Template
# Copy this file to .env inside your frontend folder and adjust.

# Centralized URL pointing to the backend Express server
VITE_API_URL=http://localhost:5000

# Public key required for client-side Razorpay checkout
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
